      <a name="label" val="B"/>
    </comp>
    <comp lib="2" loc="(140,210)" name="Multiplexer"/>
    <comp lib="5" loc="(200,210)" name="LED">
      <a name="label" val="LED1"/>
    </comp>
    <wire from="(120,230)" to="(120,280)"/>
    <wire from="(140,210)" to="(200,210)"/>
    <wire from="(60,180)" to="(90,180)"/>
    <wire from="(60,240)" to="(90,240)"/>
    <wire from="(90,180)" to="(90,200)"/>
    <wire from="(90,200)" to="(110,200)"/>
